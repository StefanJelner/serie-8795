{
  "name": "serie-8795",
  "description": "Serie 8795 - Polyrhythmic Generative Sequencer",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "npm run create:icon-service && npm run create:generators && npm run create:worklets && ng serve",
    "build": "npm run create:icon-service && npm run create:generators && npm run create:worklets && ng build",
    "watch": "npm run create:icon-service && npm run create:generators && npm run create:worklets && ng build --watch --configuration development",
    "test": "npm run create:icon-service && npm run create:generators && npm run create:worklets && ng test",
    "create:worklets": "rimraf ./public/worklets ./public/models && tsc -p tsconfig.worklets.json && rimraf ./public/models",
    "create:generators": "rimraf ./src/app/generators/generators.ts && node generate-generators.mjs",
    "create:icon-service": "node generate-icon-service.mjs"
  },
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@shoelace-style/shoelace": "^2.20.1",
    "i18next": "^25.8.14",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.20",
    "@angular/cli": "^19.2.20",
    "@angular/compiler-cli": "^19.2.0",
    "@types/jasmine": "~5.1.0",
    "ansi-colors": "^4.1.3",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.6",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.7.2"
  }
}
